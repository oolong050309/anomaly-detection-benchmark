# =========================================================================
# 异常检测项目 —— 环境变量模板
# 复制为 .env 并填入实际值后使用：cp .env.example .env
# =========================================================================

# ---------- 服务器登录（私密信息，向组长索取） ----------
SSH_HOST=
SSH_PORT=
SSH_USER=
SSH_PASSWORD=

# ---------- 数据路径 ----------
# 本地开发：./data
# 服务器（AutoDL）：/root/autodl-tmp/final_project/data
AD_DATA_ROOT=./data

AD_TABULAR_DIR=${AD_DATA_ROOT}/tabular
AD_CV_DIR=${AD_DATA_ROOT}/cv
AD_NLP_DIR=${AD_DATA_ROOT}/nlp
AD_TIMESERIES_DIR=${AD_DATA_ROOT}/timeseries
AD_GRAPH_DIR=${AD_DATA_ROOT}/graph
AD_MANIFEST=${AD_DATA_ROOT}/selected_files.json

# ---------- 实验结果输出 ----------
AD_RESULTS_DIR=./results
AD_FIGURES_DIR=./figures

# ---------- 训练相关 ----------
AD_SEED=42
AD_TEST_SIZE=0.3
CUDA_VISIBLE_DEVICES=0
TORCH_NUM_WORKERS=4

# ---------- 第三方库（可选） ----------
# HF_ENDPOINT=https://hf-mirror.com
# WANDB_API_KEY=
# WANDB_MODE=offline

LOG_LEVEL=INFO
