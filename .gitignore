# Datasets (重新跑 scripts/select_datasets.py 即可生成)
data/tabular/*.npz
data/cv/*.npz
data/nlp/*.npz
data/timeseries/*.csv
data/graph/*
!data/graph/.gitkeep
!data/**/.gitkeep
!data/selected_files.json
!data/contaminate.py
!data/__init__.py

# Generated experiment outputs
